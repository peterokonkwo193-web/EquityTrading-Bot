{
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/next" },
    { "src": "backend/api/index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "backend/api/index.ts" },
    { "src": "/health", "dest": "backend/api/index.ts" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
