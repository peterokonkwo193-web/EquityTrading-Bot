{
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/next" },
    { "src": "backend/api/index.ts", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/backend/api/index" },
    { "source": "/health", "destination": "/backend/api/index" }
  ]
}
