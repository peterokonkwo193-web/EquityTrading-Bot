DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/dbname"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
# Comma-separated list of allowed CORS origins
FRONTEND_URL="http://localhost:3000,https://equitytradingbot.com,https://www.equitytradingbot.com"
NODE_ENV="development"
# Optional: without this, verification codes are logged/returned instead of emailed.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
