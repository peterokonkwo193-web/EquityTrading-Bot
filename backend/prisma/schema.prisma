generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum Currency {
  USD
  GBP
  EUR
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AssetClass {
  CRYPTO
  FOREX
}

enum TradeDirection {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum DepositStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionType {
  DEPOSIT
  TRADE_PNL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id                    String     @id @default(uuid())
  email                 String     @unique
  passwordHash          String
  name                  String
  avatarUrl             String?
  currency              Currency   @default(USD)
  status                UserStatus @default(ACTIVE)
  emailVerified         Boolean    @default(false)
  verificationCode      String?
  verificationExpiresAt DateTime?
  resetToken            String?
  resetTokenExpiresAt   DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  accounts Account[]
  settings Settings?

  @@map("users")
}

model Account {
  id            String        @id @default(uuid())
  userId        String
  name          String
  accountNumber String        @unique
  balance       Decimal       @db.Decimal(18, 2) @default(0)
  currency      String        @default("USD")
  status        AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingStats TradingStats?
  trades       SimulatedTrade[]
  deposits     Deposit[]
  transactions Transaction[]

  @@index([userId])
  @@map("accounts")
}

model TradingStats {
  id          String   @id @default(uuid())
  accountId   String   @unique
  totalPnl    Decimal  @db.Decimal(18, 2) @default(0)
  todayPnl    Decimal  @db.Decimal(18, 2) @default(0)
  tradesCount Int      @default(0)
  winCount    Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("trading_stats")
}

model SimulatedTrade {
  id              String         @id @default(uuid())
  accountId       String
  market          String
  assetClass      AssetClass
  direction       TradeDirection
  amount          Decimal        @db.Decimal(18, 2)
  profitLoss      Decimal        @db.Decimal(18, 2) @default(0)
  status          TradeStatus    @default(OPEN)
  durationSeconds Int            @default(20)
  openedAt        DateTime       @default(now())
  closesAt        DateTime
  closedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([accountId, createdAt])
  @@map("simulated_trades")
}

model Deposit {
  id        String        @id @default(uuid())
  accountId String
  amount    Decimal       @db.Decimal(18, 2)
  currency  String
  status    DepositStatus @default(COMPLETED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("deposits")
}

model Transaction {
  id        String            @id @default(uuid())
  accountId String
  type      TransactionType
  amount    Decimal           @db.Decimal(18, 2)
  status    TransactionStatus @default(COMPLETED)
  reference String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@map("transactions")
}

model Settings {
  id                 String   @id @default(uuid())
  userId             String   @unique
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  tradeAlerts        Boolean  @default(true)
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}
